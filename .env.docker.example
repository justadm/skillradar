# Docker env template
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME_JOBS=@GridAI_Careers_bot
TELEGRAM_BOT_TOKEN_JOBS=
TELEGRAM_BOT_USERNAME_HR=@GridAI_Recruiter_bot
TELEGRAM_BOT_TOKEN_HR=
BRAND_NAME=GridAI
HR_CONTACT_HANDLE=@gridai_hr_bot
OPENAI_API_KEY=
OPENAI_MODEL_MAIN=gpt-4.1-mini
OPENAI_MODEL_MARKET=gpt-4.1-nano
LLM_CACHE_TTL_MS=86400000
USE_MOCKS=false
HH_API_BASE=https://api.hh.ru
HH_AUTH_BASE=https://hh.ru
HH_CLIENT_ID=
HH_CLIENT_SECRET=
HH_REDIRECT_URI=https://gridai.ru/oauth/hh/callback
HH_AREA_DEFAULT=113
HH_CACHE_TTL_MS=21600000
DB_PATH=/app/data/db.sqlite
APP_PORT=3000
APP_URL=https://gridai.ru
SITE_URL=https://gridai.ru
AUTH_URL=https://auth.gridai.ru
CAREER_URL=https://career.gridai.ru
HIRING_URL=https://hiring.gridai.ru
LK_URL=https://hiring.gridai.ru
ADMIN_URL=https://admin.gridai.ru
API_PUBLIC_URL=https://api.gridai.ru
WEB_PORT=3000
COOKIE_DOMAIN=.gridai.ru
WEB_HOST_PORT=13001
FRONTEND_HOST_PORT=13080
EDGE_NGINX_HOST_PORT=18088
DEFAULT_ORG_NAME=GridAI Demo
BOOTSTRAP_OWNER_EMAIL=
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=10
ADMIN_TG_IDS=
B2B_DAILY_LIMIT=3
DISABLE_BOT=false
DISABLE_WEB=false
LEAD_TG_BOT_TOKEN=
LEAD_TG_CHAT_ID=
LEAD_EMAIL_TO=
OPS_TG_BOT_TOKEN=
OPS_TG_CHAT_ID=
OPS_EMAIL_TO=
SMTP_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
AUTH_WEB_LOGIN_BASE_URL=http://web:3000
AUTH_WEB_LOGIN_SECRET=
SOCIAL_AUTH_AUTO_CREATE_PROVIDERS=
SMSC_WEBHOOK_KEY=
SMSC_ALERT_STATUSES=DELIVRD,UNDELIV
ALERT_TG_BOT_TOKEN=
ALERT_TG_CHAT_ID=
ALERT_URL=http://web:3000
ALERT_INTERVAL=60
ALERT_BOT_CONTAINER=gridai-bot
ALERT_NGINX_CONTAINER=
ALERT_ON_5XX=true

# Social OAuth (optional)
OAUTH_YANDEX_CLIENT_ID=
OAUTH_YANDEX_CLIENT_SECRET=
